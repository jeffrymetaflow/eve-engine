{
  "name": "EVE Scoring Engine Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "vscode": {
      "settings": {
        "python.terminal.activateEnvInSelectedTerminal": true,
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "njpwerner.autodocstring",
        "tamasfe.even-better-toml"
      ]
    }
  },
  // Installs system dependencies first, then python requirements
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && xargs -a packages.txt sudo apt install -y; pip3 install --user -r requirements.txt",
  
  // Launches the app automatically when the container starts
  "postAttachCommand": "streamlit run app.py --server.enableCORS false --server.enableXsrfProtection false",
  
  "portsAttributes": {
    "8501": {
      "label": "EVE Scoring App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ],
  "remoteUser": "vscode"
}
